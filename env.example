# Smart City Traffic Intelligence — Environment Variables
# Copy to .env and fill in real values.
# Run: py generate_key.py  — to auto-generate a secure API key.
# NEVER commit .env to version control.

# API authentication key — set this in Render dashboard under Environment
API_KEY=your_64_char_hex_key_here

# CORS — set to your Render URL in production
# Development:
ALLOWED_ORIGINS=http://localhost:8000
# Production (replace with your actual Render URL):
# ALLOWED_ORIGINS=https://smart-city-traffic.onrender.com
