# Smart City Traffic Intelligence — Environment Variables
# Copy this file to .env and fill in real values.
# Run: py generate_key.py  — to auto-generate a secure API key.
# NEVER commit .env to version control.

# API authentication key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_64_char_hex_key_here

# CORS — comma-separated list of allowed origins
# Development: leave as-is
# Production: replace with your actual frontend domain(s)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
# Example production: ALLOWED_ORIGINS=https://traffic.yourdomain.com,https://dashboard.yourdomain.com

# Webhook URL for proactive operator alerts (optional — leave blank to disable)
# The system fires a POST request here when any zone breaches critical thresholds
# Supports Slack incoming webhooks, Teams, PagerDuty, or any HTTP endpoint
WEBHOOK_URL=